FROM node:24-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_NG_SOAR_API_BASE=/api/ng-soar
ARG VITE_SOARCA_API_BASE=/api/soarca
ARG VITE_ROASTER_BASE=/roaster
ARG VITE_SOARCA_GUI_BASE=/executions
ARG VITE_ROASTER_EMBED_URL=http://127.0.0.1:3000
ARG VITE_SOARCA_GUI_EMBED_URL=http://127.0.0.1:8081

ENV VITE_NG_SOAR_API_BASE=$VITE_NG_SOAR_API_BASE
ENV VITE_SOARCA_API_BASE=$VITE_SOARCA_API_BASE
ENV VITE_ROASTER_BASE=$VITE_ROASTER_BASE
ENV VITE_SOARCA_GUI_BASE=$VITE_SOARCA_GUI_BASE
ENV VITE_ROASTER_EMBED_URL=$VITE_ROASTER_EMBED_URL
ENV VITE_SOARCA_GUI_EMBED_URL=$VITE_SOARCA_GUI_EMBED_URL

RUN npm run build

FROM nginx:1.29-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
